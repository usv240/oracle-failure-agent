# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/oracle_db
MONGODB_DB_NAME=oracle_db

# Google Cloud
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1

# Gemini API key (Google AI Studio → aistudio.google.com/apikey)
# Used for Gemini 3 Flash primary model (gemini-3-flash-preview)
GEMINI_API_KEY=AIza...

# Vertex AI fallback model (must be available in your GCP project)
GEMINI_MODEL=gemini-2.5-flash

# App
APP_PORT=8080
OUTPUT_DIR=outputs
APP_URL=https://your-cloud-run-url.run.app  # Public URL — used in Slack alert links

# Slack (optional) — Oracle posts monitoring alerts to this incoming webhook
# Create at: api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Google Cloud Scheduler (optional) — replace asyncio background loop with GCP cron
# Setup: gcloud scheduler jobs create http oracle-monitor-check \
#   --location=us-central1 --schedule="0 */6 * * *" \
#   --uri="https://<CLOUD_RUN_URL>/api/metrics/trigger-check" --http-method=POST
